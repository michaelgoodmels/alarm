{
  "name": "home-alarm-frontend",
  "version": "0.1.0",
  "description": "Electron + React + Radix UI Kiosk-UI for HomeAlarm",
  "main": "dist-electron/main.js",
  "author": "Michael Good",
  "license": "UNLICENSED",
  "scripts": {
    "dev": "vite",
    "electron:dev": "concurrently -k \"vite\" \"wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .\"",
    "build": "vite build && electron-builder",
    "build:pi": "vite build && electron-builder --linux --arm64"
  },
  "dependencies": {
    "@microsoft/signalr": "^8.0.7",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-separator": "^1.1.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-switch": "^1.1.1",
    "@radix-ui/react-tabs": "^1.1.1",
    "@radix-ui/react-toast": "^1.2.2",
    "@radix-ui/themes": "^3.1.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "concurrently": "^9.0.1",
    "cross-env": "^7.0.3",
    "electron": "^33.0.2",
    "electron-builder": "^25.1.8",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vite-plugin-electron": "^0.28.8",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.goodhome.alarm",
    "productName": "HomeAlarm",
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "linux": {
      "target": [
        { "target": "AppImage", "arch": ["arm64"] },
        { "target": "deb",      "arch": ["arm64"] }
      ],
      "category": "Utility"
    }
  }
}
